# 在 Vercel Serverless Function 打包阶段，pnpm 默认的 symlink node_modules
# 会触发 "invalid deployment package ... files in symlinked directories"。
# 这里切到 hoisted 模式，让依赖实际落盘到每个包的 node_modules 而非链接，
# 方便 Vercel nft 正确追踪并打包进 Lambda。
node-linker=hoisted
shamefully-hoist=true
strict-peer-dependencies=false
auto-install-peers=true
