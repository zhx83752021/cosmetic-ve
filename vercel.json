{
  "version": 2,
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "installCommand": "NODE_ENV=development pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 10,
      "includeFiles": "apps/server/{dist,prisma,node_modules/.prisma,node_modules/@prisma/client}/**"
    },
    "api/[...path].js": {
      "memory": 1024,
      "maxDuration": 10,
      "includeFiles": "apps/server/{dist,prisma,node_modules/.prisma,node_modules/@prisma/client}/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
