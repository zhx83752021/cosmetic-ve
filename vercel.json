{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "trailingSlash": false,
  "installCommand": "NODE_ENV=development pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @cosmetics/server run build && pnpm --filter @cosmetics/web build",
  "outputDirectory": "apps/web/dist",
  "builds": [
    {
      "src": "apps/server/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "apps/web/dist",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/apps/server/api/index.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/uploads/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
