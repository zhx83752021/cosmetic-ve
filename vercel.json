{
  "version": 2,
  "framework": null,
  "trailingSlash": false,
  "installCommand": "NODE_ENV=development pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/index.js" },
    { "source": "/api/:path*", "destination": "/api/index.js?__p=:path*" },
    {
      "source": "/((?!api(?:/|$)|assets/|images/|uploads/|favicon|robots|deploy-debug).*)",
      "destination": "/index.html"
    }
  ]
}
