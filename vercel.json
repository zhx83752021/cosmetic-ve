{
  "version": 2,
  "framework": null,
  "trailingSlash": false,
  "installCommand": "NODE_ENV=development pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/((?!api(?:/|$)|assets/|images/|uploads/|favicon|robots|deploy-debug).*)",
      "destination": "/index.html"
    }
  ]
}
